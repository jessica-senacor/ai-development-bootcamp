{
  "permissions": {
    "allow": [
      "Bash(.claude/statusline.sh)"
    ],
    "deny": [
      "Read(../dschtest/)",
      "Write(//**/.env)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": false,
    "failIfUnavailable": true,
    "allowUnsandboxedCommands": false,
    "permissions.disableBypassPermissionsMode": "disable",

    "filesystem": {
      "denyRead": ["~/", "../dschtest/"],
      "denyWrite": ["//**/.env", "//**/.env.*",".claude/settings.json"]
    },

    "network": {
      "allowManagedDomainsOnly": true,
      "allowedDomains": ["github.com", "localhost", "repo.maven.apache.org"]
    }
  },
  "statusLine": {
    "type": "command",
    "command": ".claude/statusline.sh"
  }
}

